# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_PATH=~/.config/solana/id.json

# SUI Configuration
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_WALLET_PATH=~/.sui/sui_config/sui.keystore

# Strategy Configuration
STRATEGY_TYPE=volatility_2sigma
# Override strategy params (JSON)
# STRATEGY_PARAMS={"atrPeriod":14,"multiplier":2.0}

# Risk Configuration
MAX_REBALANCES_PER_DAY=6
COOLDOWN_HOURS=4
CIRCUIT_BREAKER_24H_PCT=15
MAX_SLIPPAGE_BPS=50
ORACLE_DEVIATION_PCT=2

# Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Tax Export
TAX_OUTPUT_DIR=./tax-reports
TAX_BASE_CURRENCY=JPY

# Price Feed
PYTH_ENDPOINT=https://hermes.pyth.network
COINGECKO_API_KEY=

# Database
DB_PATH=./data/clmm-manager.db

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
